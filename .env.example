APP_NAME="ERP System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

#--------------------------------------------------------------------------
# Logging
#--------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

#--------------------------------------------------------------------------
# Database
#--------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp
DB_USERNAME=root
DB_PASSWORD=

#--------------------------------------------------------------------------
# JWT Authentication
#--------------------------------------------------------------------------
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

#--------------------------------------------------------------------------
# Session & Cache
#--------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=erp_

#--------------------------------------------------------------------------
# Queue & Broadcasting
#--------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

#--------------------------------------------------------------------------
# Redis
#--------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

#--------------------------------------------------------------------------
# Mail
#--------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

#--------------------------------------------------------------------------
# CORS (Comma-separated list of allowed origins for production)
#--------------------------------------------------------------------------
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

#--------------------------------------------------------------------------
# CompliPay Integration (Unified Compliance Gateway)
#--------------------------------------------------------------------------
COMPLIPAY_URL=https://api.complipay.com/v1
COMPLIPAY_API_KEY=
COMPLIPAY_WEBHOOK_SECRET=

#--------------------------------------------------------------------------
# ERP Defaults
#--------------------------------------------------------------------------
ERP_DEFAULT_CURRENCY=SAR
ERP_DEFAULT_TIMEZONE=Asia/Riyadh
ERP_DEFAULT_LANGUAGE=en

#--------------------------------------------------------------------------
# Security Settings
#--------------------------------------------------------------------------
# Maximum login attempts before lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Password requirements (applied via Password::defaults())
PASSWORD_MIN_LENGTH=8
